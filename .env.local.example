# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: Service role key bypasses Row Level Security.
# Only use in trusted server-side admin contexts. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shopify OAuth — Task 2.1
# Create a Shopify Partner app at https://partners.shopify.com to get these.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Public URL of this app (used to construct the OAuth redirect URI)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# AI Provider Keys — Task 1.5: Multi-Model AI Router
# Google AI Studio — Gemini models (free tier available)
GOOGLE_AI_KEY=
# Groq — ultra-fast inference for Llama models (free tier available)
GROQ_API_KEY=
# DeepSeek — cost-effective reasoning models
DEEPSEEK_API_KEY=
# Anthropic — Claude models
ANTHROPIC_API_KEY=
