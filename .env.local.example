# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# WARNING: Service role key bypasses Row Level Security.
# Only use in trusted server-side admin contexts. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shopify OAuth — Task 2.1
# Create a Shopify Partner app at https://partners.shopify.com to get these.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Public URL of this app (used to construct the OAuth redirect URI)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Meta Ads OAuth — Task 2.2
# Create a Meta App at https://developers.facebook.com to get these.
META_APP_ID=
META_APP_SECRET=

# Google OAuth (GA4 + Ads + Search Console) — Task 2.3
# Create credentials at https://console.cloud.google.com > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Ads developer token — required by google-ads-api to hit the Ads API.
# Apply at https://ads.google.com/aw/apicenter
GOOGLE_ADS_DEVELOPER_TOKEN=

# Stripe — Task 6.1: Billing & Credit Packs
# Get these from https://dashboard.stripe.com/apikeys and the Webhooks section.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AI Provider Keys — Task 1.5: Multi-Model AI Router
# Google AI Studio — Gemini models (free tier available)
GOOGLE_AI_KEY=
# Groq — ultra-fast inference for Llama models (free tier available)
GROQ_API_KEY=
# DeepSeek — cost-effective reasoning models
DEEPSEEK_API_KEY=
# Anthropic — Claude models
ANTHROPIC_API_KEY=

# Cron Jobs — Task 7.1: Scheduling & Cron Jobs
# Secret used to authenticate Vercel Cron invocations. Generate with: openssl rand -hex 32
CRON_SECRET=

# Error Tracking — Task 10.1: Sentry
# Create a project at https://sentry.io to get your DSN.
SENTRY_DSN=

# fal.ai — Task 1.4: Image & Video Generation
# Get your key from https://fal.ai/dashboard/keys
FAL_AI_KEY=

# Firecrawl — AI web crawling for brand extraction
# Get your key from https://firecrawl.dev — 500 free credits/month
FIRECRAWL_API_KEY=

# DataForSEO — traffic & SEO intelligence (Phase 3: Echo)
# Sign up at https://dataforseo.com — pay-as-you-go pricing
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# NewsAPI — competitor shutdown/news monitoring (Phase 4: Echo)
# Get your key from https://newsapi.org — 100 free requests/day
NEWSAPI_KEY=

# Snapchat Marketing API OAuth — Task 9 (Phase 3 deferred)
# Create a Snapchat business app at https://business.snapchat.com/ads-api
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
